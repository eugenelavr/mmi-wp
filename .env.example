# Database connection (Railway injects these from the MySQL service)
WORDPRESS_DB_HOST=
WORDPRESS_DB_USER=
WORDPRESS_DB_PASSWORD=
WORDPRESS_DB_NAME=

# Site URL (Railway provides a *.up.railway.app domain, or use your custom domain)
WORDPRESS_URL=

# WordPress admin credentials (used by install-wp.sh)
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=
WORDPRESS_ADMIN_EMAIL=admin@mmi.kpi.ua
